# ── LLM Providers ─────────────────────────────────────────────────────────────
# Used when running with -Pcloud profile
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Local Ollama (used with -Plocal profile, the default)
OLLAMA_BASE_URL=http://localhost:11434

# ── Security ───────────────────────────────────────────────────────────────────
# Minimum 32 characters (256-bit key for HS256 JWT signing)
JWT_SECRET=change-me-to-a-real-secret-of-at-least-256-bits

# ── Infrastructure ─────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=masterclass
POSTGRES_USER=masterclass
POSTGRES_PASSWORD=masterclass

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=masterclass

# ── Observability ──────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=java-ai-agents-masterclass
