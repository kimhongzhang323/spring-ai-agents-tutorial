{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "AI Agents — Production Dashboard",
  "uid": "ai-agents-prod",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "LLM Requests / minute",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [{
        "datasource": "${DS_PROMETHEUS}",
        "expr": "rate(gen_ai_client_token_usage_total[1m]) * 60",
        "legendFormat": "{{token_type}} tokens/min"
      }]
    },
    {
      "id": 2,
      "title": "P95 Agent Request Latency",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [{
        "datasource": "${DS_PROMETHEUS}",
        "expr": "histogram_quantile(0.95, rate(gen_ai_agent_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p95 latency"
      }, {
        "datasource": "${DS_PROMETHEUS}",
        "expr": "histogram_quantile(0.50, rate(gen_ai_agent_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p50 latency"
      }]
    },
    {
      "id": 3,
      "title": "Guardrail Rejection Rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "options": { "colorMode": "background", "thresholds": { "steps": [
        { "value": 0, "color": "green" },
        { "value": 5, "color": "yellow" },
        { "value": 20, "color": "red" }
      ]}},
      "targets": [{
        "datasource": "${DS_PROMETHEUS}",
        "expr": "rate(gen_ai_guardrail_rejections_total[5m]) * 60",
        "legendFormat": "rejections/min"
      }]
    },
    {
      "id": 4,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 4 },
      "targets": [{
        "datasource": "${DS_PROMETHEUS}",
        "expr": "gen_ai_agent_active_sessions",
        "legendFormat": "active sessions"
      }]
    },
    {
      "id": 5,
      "title": "LLM Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "${DS_PROMETHEUS}",
        "expr": "rate(llm_errors_total[5m])",
        "legendFormat": "errors/sec"
      }]
    },
    {
      "id": 6,
      "title": "Token Usage Cumulative",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "options": { "orientation": "horizontal" },
      "targets": [{
        "datasource": "${DS_PROMETHEUS}",
        "expr": "sum(gen_ai_client_token_usage_total) by (token_type)",
        "legendFormat": "{{token_type}}"
      }]
    }
  ]
}