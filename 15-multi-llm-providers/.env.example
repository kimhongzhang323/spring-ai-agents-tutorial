# ── Multi-LLM Providers — environment variables ──────────────────────────────
# Copy to .env and fill in the keys for the providers you want to use.
# You only need ONE provider active to run the module; Ollama works with no key.
#
# How providers activate:
#   Spring AI starters (OpenAI, Anthropic, Gemini, Mistral, Azure, Bedrock) back
#   off when their api-key property equals "not-configured".
#   OpenAI-compatible providers (Groq, DeepSeek, Together, Perplexity) activate
#   when their env var is present via @ConditionalOnProperty in ProviderConfig.java.

# ── Required for JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-256-bit-random-secret

# ── Ollama (local, no key needed) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Models: gpt-4o, gpt-4o-mini, o1, o3-mini
# Docs: https://platform.openai.com/docs
OPENAI_API_KEY=sk-...

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Models: claude-3-7-sonnet-20250219, claude-3-5-haiku-20241022
# Docs: https://docs.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini (via Vertex AI) ─────────────────────────────────────────────
# Models: gemini-2.0-flash-001, gemini-2.5-pro-preview-03-25
# Docs: https://cloud.google.com/vertex-ai/generative-ai/docs
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# Models: anthropic.claude-3-haiku, amazon.titan-text-express
# Docs: https://docs.aws.amazon.com/bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Docs: https://learn.microsoft.com/azure/ai-services/openai
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Mistral AI ────────────────────────────────────────────────────────────────
# Models: mistral-small-latest, mistral-large-latest, codestral-latest
# Docs: https://docs.mistral.ai
MISTRAL_API_KEY=...

# ── Groq (OpenAI-compatible, ultra-fast LPU inference) ────────────────────────
# Models: llama-3.1-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
# Docs: https://console.groq.com/docs
GROQ_API_KEY=gsk_...

# ── DeepSeek (OpenAI-compatible, strong reasoning at low cost) ────────────────
# Models: deepseek-chat (DeepSeek-V3), deepseek-reasoner (DeepSeek-R1)
# Docs: https://platform.deepseek.com/docs
DEEPSEEK_API_KEY=sk-...

# ── Together AI (OpenAI-compatible, 100+ open models) ────────────────────────
# Models: meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo, Qwen/Qwen2.5-72B-Instruct-Turbo
# Docs: https://docs.together.ai
TOGETHER_API_KEY=...

# ── Perplexity AI (OpenAI-compatible, web-grounded responses) ────────────────
# Models: sonar-pro, sonar, sonar-reasoning-pro
# Docs: https://docs.perplexity.ai
PERPLEXITY_API_KEY=pplx-...
