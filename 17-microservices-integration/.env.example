# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OLLAMA_BASE_URL=http://localhost:11434

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-must-be-256-bits-or-longer

# ── Databases ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_DB=agentdb
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent

MONGO_HOST=localhost
MONGO_DB=agentdb

CASSANDRA_HOST=localhost

ELASTIC_HOST=localhost

NEO4J_HOST=localhost
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

CLICKHOUSE_HOST=localhost
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PASSWORD=

# ── Messaging ─────────────────────────────────────────────────────────────────
RABBIT_HOST=localhost
RABBIT_USER=guest
RABBIT_PASSWORD=guest

KAFKA_BROKERS=localhost:9092

NATS_HOST=localhost

ARTEMIS_HOST=localhost
ARTEMIS_USER=artemis
ARTEMIS_PASSWORD=artemis

PULSAR_HOST=localhost

# ── AWS (LocalStack) ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
LOCALSTACK_HOST=localhost
# SQS/SNS/DynamoDB use test credentials with LocalStack

# ── Azure Service Bus ─────────────────────────────────────────────────────────
AZURE_SERVICEBUS_CONNECTION_STRING=Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=test

# ── Service Mesh ──────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost
DAPR_HOST=localhost
GRPC_SERVICE_HOST=localhost

# ── External REST Services (stub URLs for dev) ───────────────────────────────
FEIGN_PRICING_SERVICE_URL=http://localhost:8081
FEIGN_USER_SERVICE_URL=http://localhost:8082
GRAPHQL_SERVICE_URL=http://localhost:8083/graphql
